# Copy to .env (never commit .env):
#   cp .env.example .env
#
# Prebuilt cases work offline — no API keys required for the board UI.
ARCHIVE_DETECTIVE_USE_MODEL=0
ARCHIVE_DETECTIVE_MODEL=openbmb/MiniCPM-V-4.6

# Local llama.cpp inference (Off the Grid + Llama Champion)
# Start server: ./scripts/run_llama.sh
ARCHIVE_DETECTIVE_USE_LLAMA=0
ARCHIVE_DETECTIVE_LLAMA_URL=http://127.0.0.1:8080
ARCHIVE_DETECTIVE_LLAMA_MODEL=local
# ARCHIVE_DETECTIVE_LLAMA_BIN=~/.local/bin/llama-server
# GGUF path for run_llama.sh:
# ARCHIVE_DETECTIVE_LLAMA_MODEL=~/.cache/archive-detective/models/Qwen2.5-3B-Instruct-Q4_K_M.gguf

# Hugging Face hosted inference (no local model download)
# HF_TOKEN=hf_...
# ARCHIVE_DETECTIVE_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# ARCHIVE_DETECTIVE_HF_VISION_MODEL=openbmb/MiniCPM-V-4_6
# ARCHIVE_DETECTIVE_PREFER_LIVE=1
