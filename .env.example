# Copy to .env (never commit .env):
#   cp .env.example .env

ARCHIVE_DETECTIVE_USE_MODEL=0
ARCHIVE_DETECTIVE_MODEL=openbmb/MiniCPM-V-4.6

# OpenBMB play path — ONE Modal GPU call per gallery/upload pick:
#   ./scripts/deploy_modal_gpu.sh
ARCHIVE_DETECTIVE_MODAL_PLAY=auto
ARCHIVE_DETECTIVE_TEXT_MODEL=openbmb/MiniCPM5-1B
# ARCHIVE_DETECTIVE_TEXT_MODEL=openbmb/MiniCPM4.1-8B

# HF_TOKEN — weights download on Modal + optional Qwen fallback
HF_TOKEN=hf_...

# HF fallback only (when Modal off):
ARCHIVE_DETECTIVE_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# ARCHIVE_DETECTIVE_ALLOW_HF_CABINET=1

# Optional dev only:
# ARCHIVE_DETECTIVE_USE_CACHE=1
# ARCHIVE_DETECTIVE_ALLOW_HEURISTIC=1
# ARCHIVE_DETECTIVE_ALLOW_BUNDLED_OCR=1
